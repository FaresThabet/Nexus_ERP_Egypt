# ============================================================================
# Nexus ERP — PRODUCTION Environment Variables (Vercel / Netlify + Postgres)
# ============================================================================
# Copy this file to .env.production and fill in the values, OR set them
# directly in your Vercel / Netlify dashboard under Project Settings → Env Vars.
#
# All values below are REQUIRED unless marked OPTIONAL.
# ============================================================================

# ─── DATABASE (REQUIRED) ──────────────────────────────────────────────────
# Postgres connection string from Supabase / Neon / Railway / Vercel Postgres.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public&sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require"

# Direct URL for migrations (Supabase/Neon pooler may need a non-pooled URL)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require"

# Tell Prisma which schema to use (Postgres variant)
PRISMA_SCHEMA_PATH="prisma/schema.postgres.prisma"

# ─── APP (REQUIRED) ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Nexus ERP Egypt"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NODE_ENV="production"

# ─── AUTH (REQUIRED) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_32_PLUS_RANDOM_CHARS"
AUTH_URL="https://your-app.vercel.app"

# ─── ETA (Egyptian Tax Authority) — OPTIONAL ────────────────────────────
ETA_ENVIRONMENT="preprod"
ETA_CLIENT_ID_B2B=""
ETA_CLIENT_SECRET_B2B=""
ETA_CLIENT_ID_B2C=""
ETA_CLIENT_SECRET_B2C=""
ETA_TAXPAYER_ID=""
ETA_TAXPAYER_NAME=""
ETA_BRANCH_CODE=""

# ─── WhatsApp (Meta Cloud API) — OPTIONAL ───────────────────────────────
WHATSAPP_PROVIDER="meta_cloud"
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# ─── Paymob (Payment Gateway) — OPTIONAL ────────────────────────────────
PAYMOB_API_KEY=""
PAYMOB_INTEGRATION_ID=""
PAYMOB_IFRAME_ID=""

# ─── Fawry (Alternative Payment) — OPTIONAL ─────────────────────────────
FAWRY_MERCHANT_CODE=""
FAWRY_SECURE_KEY=""

# ─── Currency Rates (Central Bank of Egypt) — OPTIONAL ──────────────────
CBE_RATES_API_URL=""
CBE_LIVE_RATES="false"

# ─── SMTP (Email) — OPTIONAL ────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── AI Copilot — OPTIONAL ──────────────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
