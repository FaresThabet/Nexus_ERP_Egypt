# Nexus ERP Egypt — Environment Variables Example (Local Dev)
# Copy this file to .env and fill in the values for your environment.

# Database (SQLite by default — file path is relative to project root)
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# App
NEXT_PUBLIC_APP_NAME="Nexus ERP Egypt"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Auth
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"

# ETA (Egyptian Tax Authority) Integration — OPTIONAL
ETA_ENVIRONMENT="preprod"
ETA_CLIENT_ID=""
ETA_CLIENT_SECRET=""
ETA_TAXPAYER_ID=""
ETA_TAXPAYER_NAME=""
ETA_BRANCH_CODE=""

# WhatsApp (Meta Cloud API) — OPTIONAL
WHATSAPP_PROVIDER="meta_cloud"
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# Paymob (Payment Gateway) — OPTIONAL
PAYMOB_API_KEY=""
PAYMOB_INTEGRATION_ID=""
PAYMOB_IFRAME_ID=""

# Fawry (Alternative Payment Gateway) — OPTIONAL
FAWRY_MERCHANT_CODE=""
FAWRY_SECURE_KEY=""

# OpenAI (for AI Copilot features) — OPTIONAL
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Currency Rates (Central Bank of Egypt) — OPTIONAL
CBE_RATES_API_URL=""
